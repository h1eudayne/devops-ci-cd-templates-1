version: '3'
services:
  minio:
    image: minio/minio:RELEASE.2023-02-27T18-10-45Z  # Đã ghim phiên bản cũ để giữ UI cũ
    container_name: minio
    ports:
      - "9000:9000"
      - "9001:9001"
    volumes:
      - ./storage:/data
    environment:
      MINIO_ROOT_USER: h1eudayne
      MINIO_ROOT_PASSWORD: 1
    command: server --console-address ":9001" /data
